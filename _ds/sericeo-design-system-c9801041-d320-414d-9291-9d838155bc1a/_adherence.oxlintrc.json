{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "assets/icons/**",
              "components/content/**",
              "components/data/**",
              "components/feedback/**",
              "components/forms/**",
              "components/navigation/**",
              "ui_kits/sericeo/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Pretendard|Noto Sans KR|Noto Sans|Inter))/i]",
        "message": "Font not provided by the design system. Available: Pretendard, Noto Sans KR, Noto Sans, Inter."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute > JSXIdentifier[name!=/^(?:src|alt|size|ring|fallback|key|ref|className|style|children)$/]",
        "message": "<Avatar> doesn't accept that prop. Declared props: src, alt, size, ring, fallback."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:className|style|property1|text1|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: className, style, property1, text1."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='property1'] > Literal[value!=/^(?:gnb|utill)$/]",
        "message": "<Badge> property1 must be one of 'gnb' | 'utill'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|tone|size|leadingIcon|trailingIcon|disabled|fullWidth|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, tone, size, leadingIcon, trailingIcon, disabled, fullWidth, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:fill|line|text)$/]",
        "message": "<Button> variant must be one of 'fill' | 'line' | 'text'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:dark|primary|white)$/]",
        "message": "<Button> tone must be one of 'dark' | 'primary' | 'white'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg|xl)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg' | 'xl'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ButtonAlerton'] > JSXAttribute > JSXIdentifier[name!=/^(?:className|style|badge|state|icon1|icon2|key|ref|className|style|children)$/]",
        "message": "<ButtonAlerton> doesn't accept that prop. Declared props: className, style, badge, state, icon1, icon2."
      },
      {
        "selector": "JSXOpeningElement[name.name='ButtonAlerton'] > JSXAttribute[name.name='state'] > Literal[value!=/^(?:default|hover)$/]",
        "message": "<ButtonAlerton> state must be one of 'default' | 'hover'."
      },
      {
        "selector": "JSXOpeningElement[name.name='CarouselIndicator'] > JSXAttribute > JSXIdentifier[name!=/^(?:total|index|playing|controls|onPrev|onNext|onTogglePlay|key|ref|className|style|children)$/]",
        "message": "<CarouselIndicator> doesn't accept that prop. Declared props: total, index, playing, controls, onPrev, onNext, onTogglePlay."
      },
      {
        "selector": "JSXOpeningElement[name.name='ClassDetail'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|key|ref|className|style|children)$/]",
        "message": "<ClassDetail> doesn't accept that prop. Declared props: label, value."
      },
      {
        "selector": "JSXOpeningElement[name.name='CompareDatum'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|display|label|key|ref|className|style|children)$/]",
        "message": "<CompareDatum> doesn't accept that prop. Declared props: value, display, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='ContentCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:image|category|title|author|flags|width|ratio|key|ref|className|style|children)$/]",
        "message": "<ContentCard> doesn't accept that prop. Declared props: image, category, title, author, flags, width, ratio."
      },
      {
        "selector": "JSXOpeningElement[name.name='Flag'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|key|ref|className|style|children)$/]",
        "message": "<Flag> doesn't accept that prop. Declared props: children, tone."
