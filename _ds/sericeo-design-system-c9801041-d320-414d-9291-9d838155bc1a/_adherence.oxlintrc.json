        "selector": "JSXOpeningElement[name.name='Gnb'] > JSXAttribute > JSXIdentifier[name!=/^(?:className|style|icon1|icon2|key|ref|className|style|children)$/]",
        "message": "<Gnb> doesn't accept that prop. Declared props: className, style, icon1, icon2."
      },
      {
        "selector": "JSXOpeningElement[name.name='GnbMo'] > JSXAttribute > JSXIdentifier[name!=/^(?:className|style|icon1|key|ref|className|style|children)$/]",
        "message": "<GnbMo> doesn't accept that prop. Declared props: className, style, icon1."
      },
      {
        "selector": "JSXOpeningElement[name.name='Icon'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|size|key|ref|className|style|children)$/]",
        "message": "<Icon> doesn't accept that prop. Declared props: name, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='Icon16ArrowSm'] > JSXAttribute > JSXIdentifier[name!=/^(?:className|style|direction|key|ref|className|style|children)$/]",
        "message": "<Icon16ArrowSm> doesn't accept that prop. Declared props: className, style, direction."
      },
      {
