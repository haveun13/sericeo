        "selector": "JSXOpeningElement[name.name='Footer'] > JSXAttribute > JSXIdentifier[name!=/^(?:className|style|text1|text2|text3|text4|icon1|key|ref|className|style|children)$/]",
        "message": "<Footer> doesn't accept that prop. Declared props: className, style, text1, text2, text3, text4, icon1."
