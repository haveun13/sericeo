        "selector": "JSXOpeningElement[name.name='FooterMo'] > JSXAttribute > JSXIdentifier[name!=/^(?:className|style|text1|text2|text3|text4|key|ref|className|style|children)$/]",
        "message": "<FooterMo> doesn't accept that prop. Declared props: className, style, text1, text2, text3, text4."
